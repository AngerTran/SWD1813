@model IEnumerable<SWD1813.Models.Group>
@{
    ViewData["Title"] = "Groups";
}

<h2 class="page-title">Groups</h2>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<p><a asp-action="Create" class="btn btn-primary">Create Group</a></p>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Lecturer</th>
            <th>Members</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td>@g.GroupName</td>
                <td>@(g.Lecturer?.User?.FullName ?? "-")</td>
                <td>@(g.GroupMembers?.Count ?? 0)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@g.GroupId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@g.GroupId">Edit</a> |
                    <a asp-action="AssignLecturer" asp-route-id="@g.GroupId">Assign Lecturer</a> |
                    <a asp-action="AddMember" asp-route-id="@g.GroupId">Add Member</a> |
                    <a asp-action="Delete" asp-route-id="@g.GroupId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
