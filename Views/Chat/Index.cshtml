@model List<SWD1813.Models.Project>
@{
    ViewData["Title"] = "Chat dự án (realtime)";
}

<h2 class="page-title">@ViewData["Title"]</h2>

<div class="alert alert-info mb-4">
    <strong>Chat ai với ai?</strong> Mỗi <strong>dự án</strong> có <strong>một phòng chat chung</strong>. Trong phòng đó, <strong>tất cả tài khoản</strong> được phép xem dự án (cùng nhóm: Lecturer / Leader / Member, và Admin) đều thấy tin nhắn và chat với nhau — <strong>không phải chat 1-1 riêng</strong>. Tin lưu trong DB và đồng bộ realtime qua SignalR.
    <hr class="my-2" />
    Cách khác: <strong>Projects → Chi tiết dự án → nút “Chat dự án (realtime)”</strong>, hoặc từ trang <strong>Tasks</strong> cột <strong>Phòng chat</strong>.
</div>

@if (Model.Count == 0)
{
    <p class="text-muted">Bạn chưa có dự án nào được phép truy cập.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="table-light">
                <tr>
                    <th>Dự án</th>
                    <th>Nhóm</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@(p.ProjectName ?? p.ProjectId)</td>
                        <td>@(p.Group?.GroupName ?? "—")</td>
                        <td>
                            <a asp-action="Project" asp-route-id="@p.ProjectId" class="btn btn-sm btn-info text-white">Vào phòng chat</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<p class="mt-3">
    <a asp-controller="Projects" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Danh sách dự án</a>
</p>
