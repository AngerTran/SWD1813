@model SWD1813.Models.ViewModels.GitHubCommitsPageVm
@{
    ViewData["Title"] = "Commit GitHub & đóng góp";
}

<h2 class="page-title">Commit GitHub — @Model.ProjectName</h2>
<p class="text-muted small mb-3">
    Dữ liệu từ bảng <code>commits</code> (repo của dự án). Đồng bộ bằng <strong>Đồng bộ GitHub</strong> sau khi Connect GitHub.
    <strong>% theo commit</strong> = tỷ lệ số commit; <strong>% theo dòng</strong> = tỷ lệ (dòng thêm + dòng xóa) khi API có trả stats — nếu toàn 0 thì chỉ xem % commit.
</p>

<p class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-secondary btn-sm">← Quay lại chi tiết dự án</a>
    <a asp-action="ConnectGitHub" asp-route-id="@Model.ProjectId" class="btn btn-outline-primary btn-sm">Connect GitHub</a>
    <form asp-action="SyncGitHub" asp-route-id="@Model.ProjectId" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-primary btn-sm">Đồng bộ lại từ GitHub</button>
    </form>
</p>

<h3 class="mt-4">Đóng góp theo tác giả</h3>
@if (Model.TotalCommits == 0)
{
    <div class="alert alert-info">Chưa có commit. Cần <strong>Connect GitHub</strong> (URL repo + token) rồi <strong>Đồng bộ GitHub</strong>.</div>
}
else
{
    <p class="small text-muted">Tổng <strong>@Model.TotalCommits</strong> commit
        @if (Model.TotalLinesTouched > 0)
        {
            <span>· <strong>@Model.TotalLinesTouched</strong> dòng (thêm+xóa) có thống kê</span>
        }
    </p>
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-sm">
            <thead class="table-light">
                <tr>
                    <th>Tác giả</th>
                    <th>Email</th>
                    <th class="text-end">Số commit</th>
                    <th class="text-end">% theo commit</th>
                    <th class="text-end">Dòng (±)</th>
                    <th class="text-end">% theo dòng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.AuthorShares)
                {
                    <tr>
                        <td>@a.DisplayName</td>
                        <td class="small">@(a.Email ?? "—")</td>
                        <td class="text-end">@a.CommitCount</td>
                        <td class="text-end"><strong>@a.PercentByCommits%</strong></td>
                        <td class="text-end">@a.LinesTouched</td>
                        <td class="text-end">@(Model.TotalLinesTouched > 0 ? $"{a.PercentByLines}%" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h3 class="mt-4">Danh sách commit</h3>
@if (Model.Commits.Count == 0)
{
    <p class="text-muted">Không có commit để hiển thị.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-sm">
            <thead class="table-light">
                <tr>
                    <th>SHA</th>
                    <th>Message</th>
                    <th>Tác giả</th>
                    <th>Repo</th>
                    <th>Ngày</th>
                    <th class="text-end">+/-</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Commits)
                {
                    <tr>
                        <td><code>@c.ShaShort</code></td>
                        <td class="small">@(c.MessageFirstLine ?? "—")</td>
                        <td class="small">@(c.AuthorName ?? "—")</td>
                        <td class="small">@(c.RepoName ?? "—")</td>
                        <td class="small">@(c.CommitDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td class="text-end small">
                            @if (c.Additions.HasValue || c.Deletions.HasValue)
                            {
                                <span>+@(c.Additions ?? 0) / -@(c.Deletions ?? 0)</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
