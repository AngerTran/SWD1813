@model SWD1813.Models.Project
@{
    ViewData["Title"] = "Project Details";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (Model.JiraProjectKey != null && Model.JiraProjectKey.Contains('@'))
{
    <div class="alert alert-warning">Jira Project Key đang là <strong>email</strong> — sai. Vào <a asp-action="ConnectJira" asp-route-id="@Model.ProjectId">Connect Jira</a> và nhập key <strong>KAN</strong> (từ URL board Jira).</div>
}

<h2 class="page-title">@Model.ProjectName</h2>
<div class="card card-fpt mb-3">
    <div class="card-header" style="color: var(--fpt-blue);">Thông tin dự án</div>
    <div class="card-body">
        <p class="mb-1"><strong>Nhóm:</strong> @(Model.Group?.GroupName ?? "-")</p>
        <p class="mb-1"><strong>Giảng viên phụ trách:</strong> @(Model.Group?.Lecturer?.User?.FullName ?? "Chưa gán") @if (Model.Group?.Lecturer?.User?.Email != null) { <span class="text-muted">(@Model.Group.Lecturer.User.Email)</span> }</p>
        <p class="mb-1"><strong>Jira Project Key:</strong> @(Model.JiraProjectKey ?? "-")</p>
        <p class="mb-1 small text-muted">Trạng thái tích hợp: Jira token @(ViewBag.HasJiraToken == true ? "đã lưu" : "chưa lưu") · GitHub token @(ViewBag.HasGithubToken == true ? "đã lưu" : "chưa lưu")</p>
        <p class="mb-0"><strong>Thời gian:</strong> @(Model.StartDate?.ToString("yyyy-MM-dd") ?? "-") → @(Model.EndDate?.ToString("yyyy-MM-dd") ?? "-")</p>
    </div>
</div>
<p class="d-flex flex-wrap gap-2 align-items-center">
    <a asp-action="ConnectJira" asp-route-id="@Model.ProjectId" class="btn btn-primary btn-sm">Connect Jira</a>
    <a asp-action="JiraIssues" asp-route-id="@Model.ProjectId" class="btn btn-success btn-sm" title="Danh sách issue trong DB (đồng bộ sau Connect Jira)">Xem danh sách issue Jira</a>
    <a asp-action="ConnectGitHub" asp-route-id="@Model.ProjectId" class="btn btn-primary btn-sm">Connect GitHub</a>
    <a asp-action="GitHubCommits" asp-route-id="@Model.ProjectId" class="btn btn-success btn-sm" title="Commit trong DB + % đóng góp (sau Connect &amp; đồng bộ)">Xem commit &amp; đóng góp GitHub</a>
    <form asp-action="SyncJira" asp-route-id="@Model.ProjectId" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-primary btn-sm">Đồng bộ Jira</button>
    </form>
    <form asp-action="SyncGitHub" asp-route-id="@Model.ProjectId" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-primary btn-sm">Đồng bộ GitHub</button>
    </form>
    <a asp-action="Index" class="btn btn-secondary btn-sm">Quay lại</a>
</p>

<h3 class="mt-4">Jira Issues</h3>
<table class="table table-bordered table-striped">
    <thead><tr><th>Key</th><th>Summary</th><th>Status</th><th>Type</th></tr></thead>
    <tbody>
        @foreach (var i in Model.JiraIssues ?? new List<SWD1813.Models.JiraIssue>())
        {
            <tr>
                <td>@i.IssueKey</td>
                <td>@i.Summary</td>
                <td>@i.Status</td>
                <td>@i.IssueType</td>
            </tr>
        }
    </tbody>
</table>

<h3 class="mt-4">Repositories</h3>
<ul class="list-unstyled">
    @foreach (var r in Model.Repositories ?? new List<SWD1813.Models.Repository>())
    {
        <li><a href="@r.RepoUrl" target="_blank">@r.RepoName</a> (@r.GithubOwner)</li>
    }
</ul>
