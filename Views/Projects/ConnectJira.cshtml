@model SWD1813.Models.Project
@{
    ViewData["Title"] = "Connect Jira";
    var integration = ViewBag.Integration as SWD1813.Models.ApiIntegration;
}

<h2>Connect Jira - @Model.ProjectName</h2>
<form asp-action="ConnectJira" method="post">
    <input type="hidden" name="projectId" value="@Model.ProjectId" />
    <div class="form-group mb-2">
        <label for="jiraProjectKey">Jira Project Key</label>
        <input type="text" id="jiraProjectKey" name="jiraProjectKey" class="form-control" value="@Model.JiraProjectKey" placeholder="e.g. SWP" />
    </div>
    <div class="form-group mb-2">
        <label for="jiraToken">Jira API Token (optional, for sync)</label>
        <input type="password" id="jiraToken" name="jiraToken" class="form-control" value="@integration?.JiraToken" placeholder="Leave blank to keep existing" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-secondary">Cancel</a>
</form>
