@model SWD1813.Models.ViewModels.ReportsIndexVm
@{
    ViewData["Title"] = "Reports";
    var projects = Model.Projects;
    var selectedPid = Model.SelectedProjectId;
}

<h2 class="page-title">Reports</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card card-fpt mb-4">
    <div class="card-header" style="color: var(--fpt-blue);">Tạo báo cáo mới</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <form asp-controller="Reports" asp-action="CreateProjectSummary" method="post" class="d-flex flex-wrap gap-2 align-items-end">
                    <div class="flex-grow-1">
                        <label class="form-label mb-1">Tóm tắt dự án (Markdown)</label>
                        <select name="projectId" class="form-select" required>
                            <option value="">— Chọn dự án —</option>
                            @foreach (var p in projects)
                            {
                                if (selectedPid == p.ProjectId)
                                {
                                    <option value="@p.ProjectId" selected>@(p.ProjectName ?? p.ProjectId)</option>
                                }
                                else
                                {
                                    <option value="@p.ProjectId">@(p.ProjectName ?? p.ProjectId)</option>
                                }
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Tạo &amp; ghi nhận</button>
                </form>
                <p class="small text-muted mb-0 mt-2">Gộp thông tin dự án, Jira, commit (theo Dashboard). Có thể tải lại file bất cứ lúc nào từ cột File.</p>
            </div>
            <div class="col-md-6 border-start ps-md-4">
                <p class="mb-2"><strong>SRS (tài liệu yêu cầu)</strong></p>
                <a asp-controller="Srs" asp-action="Index" class="btn btn-outline-primary btn-sm">Mở trang SRS</a>
                <span class="text-muted small ms-2">Tạo .md, tải xuống hoặc ghi nhận vào danh sách này.</span>
            </div>
        </div>
    </div>
</div>

<form method="get" class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="mb-0">Lọc theo dự án</label>
    <select name="projectId" onchange="this.form.submit()" class="form-select" style="width:auto; max-width: 320px;">
        <option value="">-- Tất cả --</option>
        @foreach (var p in projects)
        {
            if (selectedPid == p.ProjectId)
            {
                <option value="@p.ProjectId" selected>@p.ProjectName</option>
            }
            else
            {
                <option value="@p.ProjectId">@p.ProjectName</option>
            }
        }
    </select>
</form>
<table class="table table-bordered table-striped">
    <thead>
        <tr><th>Type</th><th>Project</th><th>Generated</th><th>File</th></tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Reports)
        {
            <tr>
                <td>@r.ReportType</td>
                <td>@(r.Project?.ProjectName ?? "-")</td>
                <td>@(r.GeneratedAt?.ToString("yyyy-MM-dd HH:mm"))</td>
                <td>@if (!string.IsNullOrEmpty(r.FileUrl)) { <a href="@r.FileUrl" target="_blank" rel="noopener">Download</a> } else { <span>-</span> }</td>
            </tr>
        }
    </tbody>
</table>
@if (!Model.Reports.Any())
{
    <p class="text-muted">
        Chưa có báo cáo. Dùng khung <strong>Tạo báo cáo mới</strong> phía trên, hoặc <strong>SRS</strong> (tải .md / ghi nhận),
        hoặc từ <strong>Chi tiết dự án</strong> → <strong>SRS &amp; báo cáo</strong>.
    </p>
}
