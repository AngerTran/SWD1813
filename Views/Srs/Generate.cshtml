@{
    ViewData["Title"] = "Tạo SRS từ dự án";
    var projects = ViewBag.Projects as IEnumerable<SWD1813.Models.Project>;
    var selectedProjectId = ViewBag.SelectedProjectId as string;
}

<h2 class="page-title">Tạo tài liệu SRS từ dữ liệu dự án</h2>
<p class="text-muted">Chọn dự án để sinh tài liệu Đặc tả yêu cầu (SRS) từ Jira issues, tasks và thông tin nhóm/giảng viên.</p>
<div class="card card-fpt">
    <div class="card-body">
        <form method="get" asp-action="Generate" class="row g-3 align-items-end">
            <div class="col-auto">
                <label for="projectId" class="form-label fw-semibold" style="color: var(--fpt-blue);">Dự án</label>
                <select name="projectId" id="projectId" class="form-select" style="width: auto; min-width: 220px;" onchange="this.form.submit()">
                    <option value="">-- Chọn dự án --</option>
                    @if (projects != null)
                    {
                        @foreach (var p in projects)
                        {
                            <option value="@p.ProjectId" selected="@(p.ProjectId == selectedProjectId)">@p.ProjectName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Tạo SRS</button>
            </div>
        </form>
    </div>
</div>
<p class="mt-3">
    <a asp-action="Index" class="btn btn-secondary btn-sm">← Quay lại Requirements</a>
</p>
@if (projects != null && !projects.Any())
{
    <p class="text-muted mt-2">Bạn chưa tham gia dự án nào. Tạo nhóm/dự án hoặc đồng bộ Jira từ mục Projects.</p>
}
