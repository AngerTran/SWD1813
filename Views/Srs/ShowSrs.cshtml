@{
    ViewData["Title"] = "Tài liệu SRS";
    var content = ViewBag.SrsContent as string ?? "";
    var projectId = ViewBag.ProjectId as string ?? "";
    var projectName = ViewBag.ProjectName as string ?? "SRS";
}

<h2 class="page-title">Tài liệu SRS – @projectName</h2>
<div class="mb-3">
    <a asp-action="Download" asp-route-projectId="@projectId" class="btn btn-primary">Tải xuống (.md)</a>
    <a asp-action="Generate" class="btn btn-secondary">Chọn dự án khác</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại Requirements</a>
</div>
<div class="card card-fpt">
    <div class="card-body">
        <pre class="mb-0 p-3 bg-light" style="white-space: pre-wrap; font-size: 0.9rem; max-height: 70vh; overflow-y: auto;">@content</pre>
    </div>
</div>
