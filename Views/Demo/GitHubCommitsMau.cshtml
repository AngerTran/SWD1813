@model SWD1813.Models.ViewModels.GitHubCommitsPageVm
@{
    ViewData["Title"] = "Demo — Commit GitHub & đóng góp";
    var barColors = new[] { "bg-primary", "bg-success", "bg-info", "bg-warning text-dark", "bg-secondary" };
}

<div class="alert alert-success border-0 shadow-sm mb-4">
    <strong>Trang mẫu sẵn có</strong> — Dữ liệu cố định trong code (<code>GitHubCommitsDemoData</code>), dùng để thuyết trình hoặc xem giao diện khi chưa đồng bộ GitHub.
    Trang thật theo dự án: <strong>Projects → Chi tiết → Xem commit &amp; đóng góp GitHub</strong>.
</div>

<h2 class="page-title">@Model.ProjectName</h2>
<p class="text-muted small mb-3">
    Cùng logic với trang GitHubCommits: <strong>% theo commit</strong> và <strong>% theo dòng</strong> (thêm + xóa). Bên dưới có <strong>biểu đồ thanh</strong> minh họa tỷ lệ.
</p>

<p class="mb-3 d-flex flex-wrap gap-2">
    <a asp-controller="Projects" asp-action="Index" class="btn btn-secondary btn-sm">← Về danh sách dự án</a>
    <span class="btn btn-outline-secondary btn-sm disabled" aria-disabled="true">Connect GitHub (chỉ trên trang dự án)</span>
    <span class="btn btn-outline-secondary btn-sm disabled" aria-disabled="true">Đồng bộ GitHub (chỉ trên trang dự án)</span>
</p>

<h3 class="mt-4">Biểu đồ — % theo số commit</h3>
@if (Model.AuthorShares.Count > 0)
{
    <div class="row g-3 mb-4">
        @for (var i = 0; i < Model.AuthorShares.Count; i++)
        {
            var a = Model.AuthorShares[i];
            var cls = barColors[i % barColors.Length];
            <div class="col-12">
                <div class="d-flex justify-content-between small mb-1">
                    <span><strong>@a.DisplayName</strong></span>
                    <span>@a.PercentByCommits% · @a.CommitCount commit</span>
                </div>
                <div class="progress" style="height: 1.35rem;">
                    <div class="progress-bar @cls" role="progressbar"
                         style="width: @(Math.Min(100, a.PercentByCommits).ToString(System.Globalization.CultureInfo.InvariantCulture))%;"
                         aria-valuenow="@a.PercentByCommits" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        }
    </div>
}

<h3 class="mt-4">Biểu đồ — % theo dòng (thêm + xóa)</h3>
@if (Model.TotalLinesTouched > 0 && Model.AuthorShares.Count > 0)
{
    <div class="row g-3 mb-4">
        @for (var i = 0; i < Model.AuthorShares.Count; i++)
        {
            var a = Model.AuthorShares[i];
            var cls = barColors[(i + 2) % barColors.Length];
            <div class="col-12">
                <div class="d-flex justify-content-between small mb-1">
                    <span><strong>@a.DisplayName</strong></span>
                    <span>@a.PercentByLines% · @a.LinesTouched dòng</span>
                </div>
                <div class="progress" style="height: 1.35rem;">
                    <div class="progress-bar @cls" role="progressbar"
                         style="width: @(Math.Min(100, a.PercentByLines).ToString(System.Globalization.CultureInfo.InvariantCulture))%;"
                         aria-valuenow="@a.PercentByLines" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        }
    </div>
}

<h3 class="mt-4">Đóng góp theo tác giả (bảng)</h3>
<p class="small text-muted">Tổng <strong>@Model.TotalCommits</strong> commit · <strong>@Model.TotalLinesTouched</strong> dòng (thêm+xóa)</p>
<div class="table-responsive mb-4">
    <table class="table table-bordered table-striped table-sm">
        <thead class="table-light">
            <tr>
                <th>Tác giả</th>
                <th>Email</th>
                <th class="text-end">Số commit</th>
                <th class="text-end">% theo commit</th>
                <th class="text-end">Dòng (±)</th>
                <th class="text-end">% theo dòng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.AuthorShares)
            {
                <tr>
                    <td>@a.DisplayName</td>
                    <td class="small">@(a.Email ?? "—")</td>
                    <td class="text-end">@a.CommitCount</td>
                    <td class="text-end"><strong>@a.PercentByCommits%</strong></td>
                    <td class="text-end">@a.LinesTouched</td>
                    <td class="text-end">@a.PercentByLines%</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<h3 class="mt-4">Danh sách commit</h3>
<div class="table-responsive">
    <table class="table table-bordered table-striped table-sm">
        <thead class="table-light">
            <tr>
                <th>SHA</th>
                <th>Message</th>
                <th>Tác giả</th>
                <th>Repo</th>
                <th>Ngày</th>
                <th class="text-end">+/-</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Commits)
            {
                <tr>
                    <td><code>@c.ShaShort</code></td>
                    <td class="small">@(c.MessageFirstLine ?? "—")</td>
                    <td class="small">@(c.AuthorName ?? "—")</td>
                    <td class="small">@(c.RepoName ?? "—")</td>
                    <td class="small">@(c.CommitDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                    <td class="text-end small">
                        <span>+@(c.Additions ?? 0) / -@(c.Deletions ?? 0)</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
